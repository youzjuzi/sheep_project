<view class="detail-page" wx:if="{{order}}">
  <view class="section">
    <view class="header-row">
      <text class="title">订单信息</text>
      <text class="status {{order.status === 'paid' ? 'status-paid' : ''}}">{{order.status_display}}</text>
    </view>
    <view class="info-row"><text class="label">订单号</text><text class="value">{{order.order_no}}</text></view>
    <view class="info-row"><text class="label">下单时间</text><text class="value">{{order.created_at}}</text></view>
    <view class="info-row"><text class="label">支付方式</text><text class="value">{{order.payment_method_display || '余额支付'}}</text></view>
    <view class="info-row"><text class="label">实付款</text><text class="value amount">¥{{order.total_amount}}</text></view>
  </view>

  <view class="section">
    <view class="header-row">
      <text class="title">羊只清单（{{order.items.length}}只）</text>
    </view>

    <view class="item-card" wx:for="{{order.items}}" wx:key="sheep_id" wx:for-item="subItem">
      <image class="item-image" src="/images/icons/function/f1.png" mode="aspectFill"></image>
      <view class="item-main">
        <text class="item-name">羊只 #{{subItem.sheep_id}}</text>
        <text class="item-attr">耳标：{{subItem.ear_tag || '未设置'}}</text>
        <text class="item-attr">性别：{{subItem.gender}}</text>
      </view>
      <text class="item-price">¥{{subItem.price}}</text>
    </view>
  </view>
</view>

<view class="empty" wx:else>
  <text>订单信息不存在</text>
</view>
