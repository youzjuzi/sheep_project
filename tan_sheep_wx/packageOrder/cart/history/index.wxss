page {
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
}

.empty-state {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: #999;
  font-size: 28rpx;
}

.order-list {
  display: flex;
  flex-direction: column;
}

.order-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 20rpx;
}

.order-no {
  font-size: 26rpx;
  color: #666;
}

.order-status {
  font-size: 26rpx;
  font-weight: bold;
  color: #999;
}

.status-paid {
  color: #4CAF50;
}

.order-items {
  display: flex;
  flex-direction: column;
}

.order-sub-item {
  display: flex;
  margin-bottom: 20rpx;
}

.order-sub-item:last-child {
  margin-bottom: 0;
}

.sheep-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  background-color: #f0f0f0;
}

.sheep-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.sheep-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.sheep-attr {
  font-size: 24rpx;
  color: #999;
}

.sheep-price {
  font-size: 28rpx;
  color: #e64340;
  font-weight: 500;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed #eee;
}

.order-time {
  font-size: 24rpx;
  color: #aaa;
}

.footer-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.detail-link {
  font-size: 24rpx;
  color: #3f7ef7;
}

.total-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
