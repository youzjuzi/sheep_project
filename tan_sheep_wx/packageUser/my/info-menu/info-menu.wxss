/* personal-profile.wxss */
.container {
    padding: 20rpx;
    background-color: #f5f5f5;
    min-height: 100vh;
  }
  
  .section {
    background-color: #ffffff;
    padding: 20rpx;
    margin-bottom: 20rpx;
    border-radius: 10rpx;
    box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
  }
  
  .section-title {
    font-size: 28rpx;
    color: #333333;
    margin-bottom: 10rpx;
  }
  
  .profile {
    display: flex;
    align-items: center;
  }
  
  .avatar-btn {
    margin-right: 20rpx;
  }
  
  .avatar {
    width: 120rpx;
    height: 120rpx;
    border-radius: 60rpx;
    background-color: #eeeeee;
  }
  
  .nickname-container {
    flex: 1;
  }
  
  .nickname-input {
    width: 100%;
    padding: 10rpx;
    font-size: 28rpx;
    border: none;
    border-bottom: 1rpx solid #cccccc;
  }
  
  .bio-textarea {
    width: 100%;
    height: 100rpx;
    padding: 10rpx;
    font-size: 28rpx;
    border: 1rpx solid #cccccc;
    border-radius: 5rpx;
    resize: none;
  }
  
  .picker-item {
    padding: 15rpx 0;
    font-size: 28rpx;
    color: #333333;
    border-bottom: 1rpx solid #eeeeee;
  }
  
  .address-selector {
    display: flex;
    flex-direction: column;
  }
  
  .province-selector {
    margin-bottom: 10rpx;
  }
  
  .province-scroll {
    display: flex;
    padding-bottom: 10rpx;
  }
  
  .province-btn {
    margin-right: 10rpx;
    padding: 10rpx 20rpx;
    background-color: #f1f1f1;
    border: none;
    border-radius: 20rpx;
    font-size: 24rpx;
    color: #333333;
    white-space: nowrap;
  }
  
  .province-btn.selected {
    background-color: #1AAD19;
    color: #ffffff;
  }
  
  .picker, .history-picker {
    padding: 10rpx;
    background-color: #f9f9f9;
    text-align: center;
    border-radius: 5rpx;
    margin-bottom: 10rpx;
  }
  
  .history-picker {
    padding: 10rpx;
    background-color: #f1f1f1;
    text-align: center;
    border-radius: 5rpx;
    margin-bottom: 10rpx;
  }
  
  .detailed-address {
    margin-top: 10rpx;
  }
  
  .detail-input {
    width: 100%;
    padding: 10rpx;
    border: 1rpx solid #cccccc;
    border-radius: 5rpx;
  }
  
  .address-summary {
    color: #666666;
  }
  
  .btn-save, .btn-submit {
    width: 100%;
    padding: 15rpx;
    background-color: #1AAD19;
    color: #ffffff;
    text-align: center;
    border-radius: 5rpx;
    margin-top: 20rpx;
  }
  
  .btn-save:hover, .btn-submit:hover {
    background-color: #179b16;
  }
  