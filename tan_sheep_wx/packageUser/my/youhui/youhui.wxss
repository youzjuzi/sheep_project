.container {
    padding: 20rpx;
    background-color: #f5f5f5;
    min-height: 100vh;
}

.tab-bar {
    display: flex;
    justify-content: space-around;
    background-color: #fff;
    padding: 20rpx 0;
    margin-bottom: 20rpx;
    border-bottom: 1rpx solid #e0e0e0;
}

.tab-item {
    padding: 10rpx 20rpx;
    font-size: 28rpx;
    color: #666;
}

.tab-item.active {
    color: #238E23;
    font-weight: bold;
    border-bottom: 2rpx solid #238E23;
    margin-bottom: -1rpx;
}

.coupon-list {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
}

.coupon-item {
    display: flex;
    background-color: #fff;
    border-radius: 8rpx;
    border: 1rpx solid #e0e0e0;
    padding: 20rpx;
}

.coupon-left {
    flex: 1;
    display: flex;
    align-items: center;
}

.coupon-amount {
    width: 100rpx;
    height: 100rpx;
    background-color: #238E23;
    border-radius: 8rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 20rpx;
}

.coupon-amount.used,
.coupon-amount.expired {
    background-color: #ccc;
}

.amount-text {
    font-size: 32rpx;
    font-weight: bold;
    color: #fff;
}

.coupon-info {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.coupon-name {
    font-size: 28rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 8rpx;
}

.coupon-desc {
    font-size: 24rpx;
    color: #666;
    margin-bottom: 8rpx;
}

.coupon-code {
    font-size: 22rpx;
    color: #999;
    margin-bottom: 6rpx;
}

.coupon-time {
    font-size: 22rpx;
    color: #999;
    margin-bottom: 4rpx;
}

.coupon-status {
    font-size: 22rpx;
    color: #999;
}

.coupon-right {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding-left: 20rpx;
    border-left: 1rpx solid #e0e0e0;
}

.status-badge {
    padding: 6rpx 12rpx;
    border-radius: 4rpx;
    font-size: 22rpx;
    margin-bottom: 12rpx;
}

.status-badge.unused {
    background-color: #e8f5e9;
    color: #2e7d32;
}

.status-badge.used {
    background-color: #f5f5f5;
    color: #999;
}

.status-badge.expired {
    background-color: #ffebee;
    color: #c62828;
}

.use-btn {
    background-color: #238E23;
    color: #fff;
    border: none;
    border-radius: 4rpx;
    padding: 10rpx 24rpx;
    font-size: 24rpx;
}

.empty-state {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 100rpx 0;
    color: #999;
    font-size: 28rpx;
}

.loading {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 40rpx 0;
    color: #999;
    font-size: 28rpx;
}
