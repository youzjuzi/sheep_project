<!--pages/my/follows/index.wxml-->
<view class="page">
  <!-- 空状态 -->
  <view class="empty-wrap" wx:if="{{followList.length === 0}}">
    <image class="empty-img" src="/images/icons/function/f8.png" mode="aspectFit"></image>
    <text class="empty-title">还没有关注的养殖户</text>
    <text class="empty-hint">去浏览养殖户，关注你喜欢的吧～</text>
  </view>

  <!-- 关注列表 -->
  <view class="follow-list" wx:else>
    <view
      class="follow-card"
      wx:for="{{followList}}"
      wx:key="id"
      bindtap="viewBreeder"
      data-id="{{item.id}}">
      <!-- 头像 -->
      <view class="avatar-wrap">
        <image
          class="avatar"
          src="{{item.avatarUrl || '/images/icons/function/f8.png'}}"
          mode="aspectFill">
        </image>
      </view>
      <!-- 信息 -->
      <view class="info">
        <text class="name">{{item.name}}</text>
        <text class="meta">共 {{item.sheep_count || 0}} 只羊</text>
      </view>
      <!-- 取消关注按钮 -->
      <view class="unfollow-btn" catchtap="unfollow" data-id="{{item.id}}">
        <text class="unfollow-text">已关注</text>
      </view>
    </view>
  </view>
</view>
