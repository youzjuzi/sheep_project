page {
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.container {
  padding: 24rpx;
}

/* 卡片通用样式 */
.card {
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  border-bottom: 1rpx solid #f5f5f5;
}

/* 顶部头像和昵称区域 */
.top-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border-radius: 12rpx;
  width: 140rpx;
  height: 140rpx;
  border: none;
  flex-shrink: 0;
  overflow: hidden;
  line-height: 1; /* 去除按钮默认行高挤压 */
  display: block; /* 改为块级展示避免 flex 带来的变形 */
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 100%;
  height: 100%;
  display: block; /* 防止图片底部有空白间隙 */
  border-radius: 12rpx;
}

.nick-input-box {
  flex: 1;
  margin-left: 24rpx;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 16rpx;
}

.nick-input {
  font-size: 32rpx;
  color: #333;
  width: 100%;
}

.placeholder {
  color: #999;
}

/* 简介区域 */
.desc-area {
  padding: 24rpx 32rpx;
}

.desc-input {
  width: 100%;
  height: 120rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.disabled-area {
  background: #fcfcfc;
}

.disabled-text {
  color: #bbb !important;
}

.disabled-item {
  background: #fafafa;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background-color 0.2s;
}

.list-item:last-child {
  border-bottom: none;
}

.item-hover {
  background-color: #fafafa;
}

.item-label {
  font-size: 28rpx;
  color: #666;
  width: 140rpx;
}

.item-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.mobile-text {
  color: #333;
}

/* 底部按钮 */
.btn-box {
  margin-top: 40rpx;
  padding: 0 16rpx;
}

.save-btn {
  background: #238E23 !important;
  border: none !important;
  font-size: 32rpx !important;
  color: #fff !important;
  height: 88rpx !important;
  border-radius: 8rpx !important;
}