<!--components/QAChat/QAChat.wxml-->
<view class="qa-chat-container">
  <!-- 悬浮按钮 -->
  <view 
    class="qa-float-btn {{showWindow ? 'hidden' : ''}} {{isDragging ? 'dragging' : ''}}" 
    style="{{floatBtnLeft > 0 || floatBtnTop > 0 ? 'left: ' + floatBtnLeft + 'rpx; top: ' + floatBtnTop + 'rpx; right: auto; bottom: auto;' : 'right: ' + floatBtnRight + 'rpx; bottom: ' + floatBtnBottom + 'rpx;'}}"
    catchtouchstart="onTouchStart"
    catchtouchmove="onTouchMove"
    catchtouchend="onTouchEnd"
    bindtap="openChat">
    <view class="float-btn-icon">💬</view>
    <view class="float-btn-text">智能问答</view>
  </view>

  <!-- 聊天窗口 -->
  <view class="qa-window {{showWindow ? 'show' : ''}}" wx:if="{{showWindow || show}}">
    <!-- 窗口头部 -->
    <view class="qa-header">
      <view class="header-title">
        <text class="title-text">智能问答</text>
        <text class="title-subtitle">滩羊智品助手</text>
      </view>
      <view class="header-actions">
        <view class="action-btn" bindtap="clearMessages">
          <text class="icon">🗑️</text>
        </view>
        <view class="action-btn" bindtap="closeChat">
          <text class="icon">✕</text>
        </view>
      </view>
    </view>

    <!-- 消息列表 -->
    <scroll-view 
      class="messages-container" 
      scroll-y="{{true}}" 
      scroll-top="{{scrollTop}}"
      scroll-with-animation="{{true}}">
      <view class="messages-list">
        <view 
          class="message-item {{item.type}}" 
          wx:for="{{messages}}" 
          wx:key="index">
          <view class="message-avatar">
            <image 
              wx:if="{{item.type === 'bot'}}"
              class="avatar-img bot-avatar" 
              src="/images/icons/function/f1.png" 
              mode="aspectFill" />
            <view wx:else class="avatar-img user-avatar">
              <text class="avatar-text">👤</text>
            </view>
          </view>
          <view class="message-content">
            <view class="message-bubble {{item.type}}">
              <text class="message-text">{{item.content}}</text>
              <view class="message-meta">
                <text class="message-time">{{item.time}}</text>
                <text class="message-model" wx:if="{{item.modelInfo}}">{{item.modelInfo}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- 快速问题 -->
    <view class="quick-questions" wx:if="{{messages.length <= 1}}">
      <view class="quick-title">常见问题：</view>
      <view class="quick-list">
        <view 
          class="quick-item" 
          wx:for="{{quickQuestions}}" 
          wx:key="index"
          data-question="{{item}}"
          bindtap="onQuickQuestionTap">
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 输入区域 -->
    <view class="input-container">
      <view class="input-wrapper">
        <input 
          class="input-field" 
          type="text" 
          placeholder="请输入您的问题..." 
          value="{{inputValue}}"
          bindinput="onInputChange"
          confirm-type="send"
          bindconfirm="sendMessage" />
        <view class="send-btn {{inputValue ? 'active' : ''}}" bindtap="sendMessage">
          <text class="send-icon">发送</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 遮罩层 -->
  <view class="qa-mask {{showWindow ? 'show' : ''}}" bindtap="closeChat"></view>
</view>

