/* components/QAChat/QAChat.wxss */

/* 悬浮按钮 */
.qa-float-btn {
  position: fixed;
  right: 30rpx;
  bottom: 120rpx;
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #238E23 0%, #2db82d 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(35, 142, 35, 0.4);
  z-index: 999;
  transition: all 0.3s ease;
  animation: float 3s ease-in-out infinite;
  touch-action: none; /* 防止默认触摸行为 */
}

.qa-float-btn.hidden {
  opacity: 0;
  transform: scale(0);
  pointer-events: none;
}

.qa-float-btn.dragging {
  animation: none; /* 拖拽时停止浮动动画 */
  box-shadow: 0 12rpx 30rpx rgba(35, 142, 35, 0.6); /* 拖拽时增强阴影 */
  transform: scale(1.1); /* 拖拽时稍微放大 */
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.float-btn-icon {
  font-size: 48rpx;
  margin-bottom: 4rpx;
}

.float-btn-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: bold;
}

/* 聊天窗口 */
.qa-window {
  position: fixed;
  right: 30rpx;
  bottom: 120rpx;
  width: 680rpx;
  height: 80vh;
  max-height: 900rpx;
  background-color: #fff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.2);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  transform: translateY(100vh);
  opacity: 0;
  transition: all 0.3s ease;
  overflow: hidden;
}

.qa-window.show {
  transform: translateY(0);
  opacity: 1;
}

/* 遮罩层 */
.qa-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.qa-mask.show {
  opacity: 1;
  pointer-events: auto;
}

/* 顶部标题栏 */
.qa-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #238E23;
  color: #fff;
  flex-shrink: 0;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.header-title {
  display: flex;
  flex-direction: column;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
}

.title-subtitle {
  font-size: 22rpx;
  opacity: 0.9;
  margin-top: 4rpx;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  padding: 10rpx;
  font-size: 32rpx;
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background-color 0.2s;
}

.action-btn:active {
  background-color: rgba(255, 255, 255, 0.2);
}

/* 消息列表容器 */
.messages-container {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
  min-height: 0;
  box-sizing: border-box;
}

.messages-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

/* 消息项 */
.message-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  box-sizing: border-box;
  width: 100%;
  animation: fadeIn 0.3s ease-in;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 用户消息右对齐 */
.message-item.user {
  flex-direction: row-reverse;
  padding-right: 12rpx;
}

/* 头像 */
.message-avatar {
  width: 60rpx;
  height: 60rpx;
  flex-shrink: 0;
  overflow: visible; /* 确保头像不被裁剪 */
}

.avatar-img {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  display: block;
  overflow: hidden;
  box-sizing: border-box;
}

.bot-avatar {
  background-color: #e0e0e0;
}

.user-avatar {
  background-color: #238E23;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-text {
  font-size: 32rpx;
  line-height: 1;
  display: block;
}

/* 消息内容 */
.message-content {
  max-width: calc(100% - 80rpx);
  min-width: 0;
}

.message-bubble {
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  position: relative;
  word-wrap: break-word;
  word-break: break-all;
}

/* 机器人消息 */
.message-bubble.bot {
  background-color: #f0f0f0;
  color: #333;
  border: 1rpx solid #e0e0e0;
}

/* 用户消息 */
.message-bubble.user {
  background-color: #238E23;
  color: #fff;
}

.message-text {
  font-size: 26rpx;
  line-height: 1.6;
  white-space: pre-wrap;
}

.message-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.message-time {
  font-size: 20rpx;
  opacity: 0.6;
  margin-top: 8rpx;
  text-align: right;
}

.message-model {
  font-size: 18rpx;
  opacity: 0.5;
  font-style: italic;
  text-align: right;
}

.message-bubble.bot .message-time,
.message-bubble.bot .message-model {
  text-align: left;
}

/* 快速问题 */
.quick-questions {
  padding: 20rpx 30rpx;
  background-color: #f9f9f9;
  border-top: 1rpx solid #e0e0e0;
  flex-shrink: 0;
}

.quick-title {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.quick-item {
  padding: 10rpx 20rpx;
  background-color: #fff;
  border-radius: 30rpx;
  font-size: 22rpx;
  color: #333;
  border: 1rpx solid #e0e0e0;
}

.quick-item:active {
  background-color: #238E23;
  color: #fff;
  border-color: #238E23;
}

/* 输入区域 */
.input-container {
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-top: 1rpx solid #e0e0e0;
  flex-shrink: 0;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-radius: 0 0 24rpx 24rpx;
  overflow: hidden;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background-color: #f5f5f5;
  border-radius: 50rpx;
  padding: 8rpx 20rpx;
}

.input-field {
  flex: 1;
  font-size: 26rpx;
  padding: 8rpx 0;
}

.send-btn {
  padding: 10rpx 24rpx;
  background-color: #ccc;
  color: #fff;
  border-radius: 30rpx;
  font-size: 24rpx;
  transition: all 0.3s;
}

.send-btn.active {
  background-color: #238E23;
}

.send-icon {
  font-size: 24rpx;
}

/* 防止滚动穿透 */
.prevent-touch-move {
  touch-action: none;
}

