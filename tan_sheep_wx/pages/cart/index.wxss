page {
    background-color: #f7f8fa; /* 采用浅灰背景突出卡片 */
    padding-bottom: 180rpx; /* 留出底部结算栏和tabBar空间 */
}

.cart-container {
    padding: 24rpx;
}

/* ===== 购买历史入口卡片 ===== */
.history-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: #fff;
    padding: 30rpx 24rpx;
    border-radius: 16rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
    transition: all 0.2s ease;
}

.history-bar-hover {
    background-color: #f2f3f5;
    transform: scale(0.98);
}

.history-left {
    display: flex;
    align-items: center;
}

.history-icon {
    margin-right: 12rpx;
}

.history-text {
    font-size: 30rpx;
    font-weight: bold;
    color: #333;
}

.history-right {
    display: flex;
    align-items: center;
}

.history-desc {
    font-size: 24rpx;
    color: #999;
    margin-right: 8rpx;
}

/* ===== 购物车标题 ===== */
.cart-title {
    display: flex;
    align-items: baseline;
    margin-bottom: 24rpx;
    padding: 0 10rpx;
}

.title-text {
    font-size: 34rpx;
    font-weight: bold;
    color: #333;
    margin-right: 16rpx;
}

.count-text {
    font-size: 24rpx;
    color: #999;
}

/* ===== 购物车商品列表 ===== */
.cart-list {
    display: flex;
    flex-direction: column;
    gap: 24rpx;
}

.cart-item {
    display: flex;
    background-color: #fff;
    border-radius: 16rpx;
    padding: 24rpx;
    box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.cart-image {
    width: 160rpx;
    height: 160rpx;
    border-radius: 12rpx;
    margin-right: 24rpx;
    background-color: #f5f5f5;
    flex-shrink: 0;
}

.cart-details {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.cart-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
}

.sheep-name {
    font-weight: bold;
    font-size: 30rpx;
    color: #333;
}

.delete-icon {
    padding: 4rpx;
}

.sheep-tags {
    display: flex;
    gap: 12rpx;
    margin-top: 12rpx;
}

.tag {
    font-size: 22rpx;
    color: #666;
    background-color: #f5f5f5;
    padding: 4rpx 12rpx;
    border-radius: 6rpx;
}

.cart-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-top: auto;
}

.price-box {
    color: #FF5700; /* 突出品牌色或醒目的橙红色 */
    display: flex;
    align-items: baseline;
}

.price-symbol {
    font-size: 24rpx;
    font-weight: bold;
    margin-right: 4rpx;
}

.price-text {
    font-size: 36rpx;
    font-weight: bold;
}

.quantity-box {
    display: flex;
    align-items: center;
    color: #999;
    font-size: 26rpx;
}

.qty-label {
    margin-right: 4rpx;
    font-size: 22rpx;
}

/* ===== 底部悬浮结算栏 ===== */
.checkout-bar-wrapper {
    position: fixed;
    bottom: 0; /* 根据 custom-tab-bar 需要适配实际高度，因为使用了 Vant 或自定义 tabBar */
    bottom: calc(env(safe-area-inset-bottom) + 100rpx); /* 兼容 tabBar 高度 */
    left: 0;
    width: 100%;
    z-index: 100;
    background-color: #fff;
    box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
}

.checkout-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 110rpx;
    padding: 0 32rpx;
    box-sizing: border-box;
    width: 100%;
}

.total-info {
    display: flex;
    align-items: baseline;
}

.total-label {
    font-size: 28rpx;
    color: #333;
    margin-right: 12rpx;
}

.total-symbol {
    font-size: 26rpx;
    color: #FF5700;
    font-weight: bold;
}

.total-price {
    font-size: 40rpx;
    font-weight: bold;
    color: #FF5700;
}

.checkout-button {
    background: linear-gradient(90deg, #FF7B00, #FF5700);
    color: #fff;
    font-size: 30rpx;
    font-weight: bold;
    height: 76rpx;
    line-height: 76rpx;
    border-radius: 38rpx;
    padding: 0 60rpx;
    margin: 0;
    border: none;
    box-shadow: 0 4rpx 12rpx rgba(255,87,0,0.3);
}

.checkout-hover {
    opacity: 0.9;
    transform: scale(0.98);
}

/* ===== 空购物车状态 ===== */
.empty-cart {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 120rpx;
}

.empty-image {
    width: 240rpx;
    height: 240rpx;
    margin-bottom: 30rpx;
    opacity: 0.5;
}

.empty-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 16rpx;
}

.empty-hint {
    font-size: 26rpx;
    color: #999;
    margin-bottom: 40rpx;
}

.go-adopt-button {
    background-color: #fff;
    color: #FF5700;
    border: 2rpx solid #FF5700;
    border-radius: 40rpx;
    padding: 0 60rpx;
    height: 70rpx;
    line-height: 66rpx;
    font-size: 28rpx;
}
