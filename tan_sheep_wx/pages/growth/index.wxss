/* 容器 */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #f0f9ff 0%, #f5f5f5 100%);
  min-height: 100vh;
}

/* 搜索区域 */
.search-section {
  margin-bottom: 30rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.search-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
  color: #238E23;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.search-button {
  background: linear-gradient(135deg, #238E23 0%, #4CAF50 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 8rpx rgba(35, 142, 35, 0.3);
}

/* 卡片通用样式 */
.card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  animation: fadeInUp 0.4s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card-header {
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  border-bottom: 1rpx solid #f0f0f0;
}

.card-title {
  display: flex;
  align-items: center;
}

.title-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.record-count {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
  font-weight: normal;
}

.card-body {
  padding: 24rpx 30rpx;
}

/* 基本信息卡片 */
.sheep-info-card {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.info-item {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.info-item.highlight {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  grid-column: span 2;
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.info-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #238E23;
}

.info-value .unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
}

/* 性别颜色 - 已通过内联样式实现，这里保留备用 */

/* 图表卡片（已移除，保留占位） */

/* 记录列表 */
.record-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.date-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.date-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.record-data {
  display: flex;
  justify-content: space-around;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 16rpx;
}

.data-item {
  text-align: center;
  flex: 1;
}

.data-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.data-value {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.data-value.weight {
  color: #ff6b6b;
}

.data-value.height {
  color: #51cf66;
}

.data-value.length {
  color: #4dabf7;
}

/* 喂养记录 */
.feeding-card {
  background: #fff;
  overflow: visible;
}

/* ── 摘要统计条 ── */
.feed-stats-bar {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #d1fae5;
}

.feed-stat-item {
  flex: 1;
  text-align: center;
}

.feed-stat-sep {
  width: 1rpx;
  height: 56rpx;
  background: #a7f3d0;
}

.feed-stat-num {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #238E23;
  line-height: 1.2;
}

.feed-stat-top {
  font-size: 26rpx; /* 饲料名称可能较长，稍小 */
}

.feed-stat-label {
  display: block;
  font-size: 20rpx;
  color: #6b7280;
  margin-top: 4rpx;
}

/* ── 记录行列表 ── */
.feed-list {
  padding: 0 20rpx 8rpx;
}

.feed-row {
  display: flex;
  align-items: center;
  padding: 18rpx 10rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.feed-row:last-child {
  border-bottom: none;
}

.feed-date {
  font-size: 22rpx;
  color: #9ca3af;
  width: 160rpx;
  flex-shrink: 0;
}

.feed-tag {
  flex: 1;
  font-size: 22rpx;
  font-weight: 500;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  text-align: center;
  margin: 0 16rpx;
}

/* 饲料颜色标签 */
.feed-grass   { background: #dcfce7; color: #166534; }
.feed-corn    { background: #fef9c3; color: #854d0e; }
.feed-pellet  { background: #fee2e2; color: #991b1b; }
.feed-hay     { background: #ffedd5; color: #9a3412; }
.feed-soybean { background: #ede9fe; color: #5b21b6; }
.feed-bran    { background: #fef3c7; color: #78350f; }
.feed-carrot  { background: #ffedd5; color: #c2410c; }
.feed-salt    { background: #dbeafe; color: #1e40af; }
.feed-default { background: #f3f4f6; color: #4b5563; }

.feed-amount-wrap {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
  flex-shrink: 0;
}

.feed-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: #238E23;
}

.feed-unit {
  font-size: 20rpx;
  color: #9ca3af;
}

/* 疫苗接种记录 */
.vaccine-item {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  border-left: 4rpx solid #4dabf7;
}

.vaccine-item:last-child {
  margin-bottom: 0;
}

.vaccine-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.vaccine-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.vaccine-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.vaccine-status.valid {
  background: #e8f5e9;
  color: #238E23;
}

.vaccine-status.expired {
  background: #ffebee;
  color: #f44336;
}

.vaccine-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.vaccine-date {
  font-size: 24rpx;
  color: #666;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-tip {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* ══════════════════════════════════════════════════
   ① 数据概览卡片
══════════════════════════════════════════════════ */
.overview-card {
  background: linear-gradient(135deg, #ffffff 0%, #f0fdf4 100%);
}

.sheep-tag {
  margin-left: auto;
  font-size: 22rpx;
  color: #555;
  background: #e8f5e9;
  border-radius: 20rpx;
  padding: 4rpx 18rpx;
}

.overview-body {
  padding: 30rpx 30rpx 24rpx;
}

/* 主指标 */
.metric-main {
  text-align: center;
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid #edf2ed;
  margin-bottom: 28rpx;
}

.metric-main-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  letter-spacing: 2rpx;
  margin-bottom: 10rpx;
}

.metric-main-val {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 6rpx;
}

.metric-main-num {
  font-size: 96rpx;
  font-weight: 700;
  color: #ff6b6b;
  line-height: 1;
}

.metric-main-unit {
  font-size: 30rpx;
  color: #bbb;
  padding-bottom: 14rpx;
}

/* 次要指标行 */
.metric-row {
  display: flex;
  align-items: center;
}

.metric-cell {
  flex: 1;
  text-align: center;
}

.metric-sep {
  width: 1rpx;
  height: 64rpx;
  background: #e0e0e0;
}

.metric-cell-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.metric-cell-val {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 4rpx;
}

.metric-cell-num {
  font-size: 42rpx;
  font-weight: 600;
  line-height: 1;
}

.metric-cell-unit {
  font-size: 20rpx;
  color: #bbb;
  padding-bottom: 4rpx;
}

.gain-color   { color: #ff6b6b; }
.height-color { color: #51cf66; }
.length-color { color: #4dabf7; }

/* ══════════════════════════════════════════════════
   ③ 紧凑型数据表格
══════════════════════════════════════════════════ */
.table-body {
  padding: 0 0 8rpx;
}

.tbl-head {
  display: flex;
  background: linear-gradient(135deg, #238E23 0%, #4CAF50 100%);
  padding: 18rpx 16rpx;
}

.tbl-row {
  display: flex;
  padding: 16rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
  align-items: center;
}

.row-stripe {
  background: #f7fdf7;
}

.th {
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
}

.td {
  font-size: 22rpx;
  color: #444;
  text-align: center;
}

.col-date { flex: 3; text-align: left; }
.col-num  { flex: 2; }
.col-diff { flex: 2; }

.td-weight { color: #ff6b6b; font-weight: 500; }
.td-height { color: #51cf66; font-weight: 500; }
.td-length { color: #4dabf7; font-weight: 500; }

.diff-up      { color: #238E23; font-weight: 600; }
.diff-neutral { color: #bbb; }

/* ══════════════════════════════════════════════════
   分页控制
══════════════════════════════════════════════════ */
.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 20rpx 16rpx;
  gap: 24rpx;
}

.page-btn {
  background: linear-gradient(135deg, #238E23 0%, #4CAF50 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 14rpx 40rpx;
  font-size: 26rpx;
  min-width: 150rpx;
  box-shadow: 0 2rpx 8rpx rgba(35, 142, 35, 0.3);
}

.page-btn[disabled] {
  background: #e0e0e0 !important;
  color: #aaa !important;
  box-shadow: none !important;
}

.page-info {
  font-size: 26rpx;
  color: #666;
  min-width: 130rpx;
  text-align: center;
}
