/* 容器 */
.container {
  padding: 20rpx;
  background: linear-gradient(180deg, #f0f9ff 0%, #f5f5f5 100%);
  min-height: 100vh;
}

/* 搜索区域 */
.search-section {
  margin-bottom: 30rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.search-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
  color: #238E23;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.search-button {
  background: linear-gradient(135deg, #238E23 0%, #4CAF50 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 8rpx rgba(35, 142, 35, 0.3);
}

/* 卡片通用样式 */
.card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  animation: fadeInUp 0.4s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card-header {
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  border-bottom: 1rpx solid #f0f0f0;
}

.card-title {
  display: flex;
  align-items: center;
}

.title-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.record-count {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
  font-weight: normal;
}

.card-body {
  padding: 24rpx 30rpx;
}

/* 基本信息卡片 */
.sheep-info-card {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.info-item {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.info-item.highlight {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  grid-column: span 2;
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.info-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #238E23;
}

.info-value .unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
}

/* 性别颜色 - 已通过内联样式实现，这里保留备用 */

/* 图表卡片 */
.chart-card {
  background: #fff;
}

ec-canvas {
  width: 100%;
  height: 500rpx;
  display: block;
}

/* 记录列表 */
.record-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.date-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.date-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.record-data {
  display: flex;
  justify-content: space-around;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 16rpx;
}

.data-item {
  text-align: center;
  flex: 1;
}

.data-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.data-value {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.data-value.weight {
  color: #ff6b6b;
}

.data-value.height {
  color: #51cf66;
}

.data-value.length {
  color: #4dabf7;
}

/* 喂养记录 */
.feeding-item {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.feeding-item:last-child {
  margin-bottom: 0;
}

.feeding-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.feeding-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.feeding-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #238E23;
}

.feeding-date {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.date-range {
  color: #666;
}

.date-separator {
  margin: 0 8rpx;
  color: #999;
}

.date-range.ongoing {
  color: #238E23;
  font-weight: 500;
}

/* 疫苗接种记录 */
.vaccine-item {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  border-left: 4rpx solid #4dabf7;
}

.vaccine-item:last-child {
  margin-bottom: 0;
}

.vaccine-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.vaccine-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.vaccine-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.vaccine-status.valid {
  background: #e8f5e9;
  color: #238E23;
}

.vaccine-status.expired {
  background: #ffebee;
  color: #f44336;
}

.vaccine-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.vaccine-date {
  font-size: 24rpx;
  color: #666;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-tip {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
  