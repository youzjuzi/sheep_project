/* pages/trace/detail.wxss */
.trace-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 80vh;
}

/* 错误状态 */
.error-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 80vh;
  padding: 40rpx;
}

.error-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.error-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-top: 30rpx;
  margin-bottom: 20rpx;
}

.error-message {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 40rpx;
  white-space: pre-line;
}

.error-actions {
  display: flex;
  gap: 20rpx;
}

/* 头部卡片 */
.header-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.3);
}

.ear-tag-section {
  text-align: center;
  margin-bottom: 30rpx;
}

.ear-tag-section .label {
  display: block;
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
  margin-bottom: 15rpx;
}

.ear-tag {
  display: block;
  color: #fff;
  font-size: 48rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

/* 二维码区域 */
.qr-code-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 30rpx;
  backdrop-filter: blur(10rpx);
}

.qr-code-image {
  width: 300rpx;
  height: 300rpx;
  background: white;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.qr-tip {
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
}

/* 信息卡片 */
.info-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.card-title text {
  margin-left: 10rpx;
}

/* 信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 25rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.info-item .label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.info-item .value {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

/* 养殖户信息 */
.breeder-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.breeder-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.breeder-item .label {
  font-size: 28rpx;
  color: #666;
}

.breeder-item .value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 底部按钮 */
.bottom-actions {
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}
