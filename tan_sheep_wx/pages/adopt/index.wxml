<!--pages/adopt/index.wxml-->
<view class="container">
    <!-- 顶部品牌横幅 -->
    <view class="brand-banner">
        <view class="brand-content">
            <text class="brand-title">滩羊定制领养</text>
            <text class="brand-subtitle">源自宁夏盐池 生态散养 品质保证</text>
        </view>
    </view>
    
    <!-- 筛选卡片 - 悬浮感 -->
    <view class="filter-card">
        <!-- 卡片标题 -->
        <view class="card-header">
            <view>
                <text class="card-title">筛选您的专属滩羊</text>
                <text class="card-subtitle">按体征与性别智能匹配</text>
            </view>
            <view class="count-badge">
                <text class="count-value">{{sheepCount}}</text>
                <text class="count-label">只可选</text>
            </view>
        </view>
        
        <!-- 性别选择 - 单选 -->
        <view class="filter-section">
            <view class="section-title">
                <view class="title-icon gender-icon"></view>
                <text>性别</text>
            </view>
            <view class="tag-row">
                <view class="tag-item {{selectedGender === '雄性' ? 'tag-active' : ''}}" 
                      bindtap="selectGender" data-value="雄性">
                    <text class="tag-text">公羊</text>
                </view>
                <view class="tag-item {{selectedGender === '雌性' ? 'tag-active' : ''}}" 
                      bindtap="selectGender" data-value="雌性">
                    <text class="tag-text">母羊</text>
                </view>
            </view>
        </view>
        
        <!-- 体重选择 - 网格布局，多选 -->
        <view class="filter-section">
            <view class="section-title">
                <view class="title-icon weight-icon"></view>
                <text>体重</text>
            </view>
            <view class="option-grid">
                <view class="option-card {{selectedWeights[index] ? 'tag-active' : ''}}" 
                      wx:for="{{weightOptions}}" wx:key="value"
                      bindtap="toggleWeight" data-index="{{index}}">
                    <text class="option-value">{{item.label}}</text>
                    <text class="option-desc">{{item.desc}}</text>
                </view>
            </view>
        </view>

        <!-- 体高选择 - 卡片网格，多选 -->
        <view class="filter-section">
            <view class="section-title">
                <view class="title-icon height-icon"></view>
                <text>体高</text>
            </view>
            <view class="option-grid">
                <view class="option-card {{selectedHeights[index] ? 'tag-active' : ''}}" 
                      wx:for="{{heightOptions}}" wx:key="value"
                      bindtap="toggleHeight" data-index="{{index}}">
                    <text class="option-value">{{item.label}}</text>
                    <text class="option-desc">{{item.desc}}</text>
                </view>
            </view>
        </view>

        <!-- 体长选择 - 卡片网格，多选 -->
        <view class="filter-section">
            <view class="section-title">
                <view class="title-icon length-icon"></view>
                <text>体长</text>
            </view>
            <view class="option-grid">
                <view class="option-card {{selectedLengths[index] ? 'tag-active' : ''}}" 
                      wx:for="{{lengthOptions}}" wx:key="value"
                      bindtap="toggleLength" data-index="{{index}}">
                    <text class="option-value">{{item.label}}</text>
                    <text class="option-desc">{{item.desc}}</text>
                </view>
            </view>
        </view>
    </view>
    
    <!-- 底部安全区域占位 -->
    <view class="safe-area-placeholder"></view>
    
    <!-- 底部悬浮操作栏 -->
    <view class="action-bar">
        <view class="action-content">
            <view class="reset-btn" bindtap="resetFilter">
                <text>重置</text>
            </view>
            <view class="confirm-btn" bindtap="searchSheep">
                <text>提交筛选</text>
            </view>
        </view>
        <view class="safe-area-bottom"></view>
    </view>
    
    <!-- 加载中提示 -->
    <view class="loading-mask" wx:if="{{loading}}">
        <view class="loading-box">
            <view class="loading-spinner"></view>
            <text class="loading-text">正在寻找优质滩羊...</text>
        </view>
    </view>
</view>
