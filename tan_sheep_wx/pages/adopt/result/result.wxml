<!--pages/adopt/result/result.wxml-->
<view class="container">
    <view class="result-header">
        <text class="result-title">找到 {{sheepList.length}} 只符合条件的羊只</text>
    </view>

    <!-- 搜索结果列表 -->
    <view class="sheep-list" wx:if="{{sheepList.length > 0}}">
        <view class="sheep-item" wx:for="{{pagedSheepList}}" wx:key="id" bindtap="viewSheepDetail" data-id="{{item.id}}">
            <view class="sheep-avatar">
                <image wx:if="{{item.image}}" src="{{item.image}}" class="avatar-img" mode="aspectFill"></image>
                <text wx:else class="avatar-icon">🐑</text>
            </view>
            <view class="sheep-info">
                <view class="sheep-id">羊只 #{{item.id}}</view>
                <view class="sheep-details">
                    <text class="detail-item">{{item.gender}}</text>
                    <text class="detail-item">{{item.weight}}kg</text>
                    <text class="detail-item">{{item.height}}cm</text>
                    <text class="detail-item">{{item.length}}cm</text>
                </view>
            </view>
            <view class="sheep-action">
                <text class="action-arrow">›</text>
            </view>
        </view>

        <view class="pagination" wx:if="{{totalPages > 1}}">
            <view class="page-btn {{currentPage <= 1 ? 'page-btn-disabled' : ''}}" bindtap="goFirstPage">
                <text>首页</text>
            </view>
            <view class="page-btn {{currentPage <= 1 ? 'page-btn-disabled' : ''}}" bindtap="goPrevPage">
                <text>上一页</text>
            </view>
            <text class="page-info">第 {{currentPage}} / {{totalPages}} 页</text>
            <view class="page-btn {{currentPage >= totalPages ? 'page-btn-disabled' : ''}}" bindtap="goNextPage">
                <text>下一页</text>
            </view>
            <view class="page-btn {{currentPage >= totalPages ? 'page-btn-disabled' : ''}}" bindtap="goLastPage">
                <text>末页</text>
            </view>
        </view>

        <view class="jump-row" wx:if="{{totalPages > 1}}">
            <text class="jump-label">跳转到</text>
            <input class="jump-input" type="number" placeholder="页码" value="{{jumpPageInput}}" bindinput="onJumpInput" />
            <view class="jump-btn" bindtap="jumpToPage">
                <text>确定</text>
            </view>
        </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{sheepList.length === 0}}">
        <view class="empty-icon">🐑</view>
        <text class="empty-text">暂无搜索结果</text>
        <text class="empty-hint">请尝试其他筛选条件</text>
    </view>
</view>
