page {
  background: #f9f6f1;
}

.container {
  padding-bottom: 60rpx;
  background: #f9f6f1;
}

.recipe-image {
  width: 100%;
  height: 440rpx;
  display: block;
}

.recipe-info {
  padding: 32rpx 28rpx 0;
}

.recipe-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #2c2018;
  margin-bottom: 28rpx;
  line-height: 1.4;
}

/* 区块卡片 */
.section-block {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 28rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 区块标题 */
.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-bar {
  width: 8rpx;
  height: 36rpx;
  background: #8B4513;
  border-radius: 4rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #5a3010;
}

/* 食材列表 */
.ing-list {
  display: flex;
  flex-wrap: wrap;
}

.ing-item {
  display: flex;
  align-items: flex-start;
  width: 50%;
  padding: 6rpx 0;
}

.ing-dot {
  color: #c8a055;
  font-size: 32rpx;
  line-height: 1.4;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.ing-name {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
}

/* 步骤列表 */
.step-list {
  padding: 0;
}

.step-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.step-item:last-child {
  margin-bottom: 0;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  background: #8B4513;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  margin-top: 4rpx;
}

.step-num text {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.step-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.9;
  flex: 1;
}