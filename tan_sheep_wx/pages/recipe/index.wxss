
.root {
    display: flex;
    flex-direction: column;
}

.item {
    display: flex;
    align-items: center;
    justify-content: space-between; 
    padding: 10px;
}

.symbol {
    margin-left: auto;
}


.background-image {
    width: 50px;
    height: 50px;
    margin-right: 10px;
}

.content {
    font-size: 16px;
}
.divider {
    height: 1px;
    background: linear-gradient(to right, red, orange, yellow, green, blue, indigo, violet);
    margin: 5px 0;
}

