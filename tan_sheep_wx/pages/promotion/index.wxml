<view class="container">
    <!-- 优惠券列表 -->
    <view class="content">
        <view class="coupon-list" wx:if="{{coupons.length > 0}}">
            <view class="coupon-item" wx:for="{{coupons}}" wx:key="id">
                <view class="coupon-left">
                    <view class="coupon-amount">
                        <text class="amount-text" wx:if="{{item.coupon_type === 'discount' || item.coupon_type === 'cash'}}">¥{{item.discount_amount}}</text>
                        <text class="amount-text" wx:elif="{{item.coupon_type === 'percentage'}}">{{Math.round(item.discount_rate * 100)}}折</text>
                    </view>
                    <view class="coupon-info">
                        <text class="coupon-name">{{item.name}}</text>
                        <!-- 显示养殖户信息 -->
                        <text class="coupon-owner" wx:if="{{item.owner}}">仅限购买 {{item.owner.farm_name || item.owner.name}} 的羊只使用</text>
                        <text class="coupon-desc">{{item.displayText}}</text>
                        <text class="coupon-time">有效期至：{{item.valid_until}}</text>
                    </view>
                </view>
                <view class="coupon-right">
                    <view class="claim-btn {{item.remaining_count === 0 ? 'disabled' : ''}}" bindtap="claimCoupon" data-id="{{item.id}}">
                        {{item.remaining_count === 0 ? '已领完' : '领取'}}
                    </view>
                    <text class="coupon-limit" wx:if="{{item.remaining_count !== null}}">剩余{{item.remaining_count}}张</text>
                </view>
            </view>
        </view>
        <view class="empty-state" wx:else>
            <text>暂无可用优惠券</text>
        </view>
    </view>

    <!-- 加载中 -->
    <view class="loading" wx:if="{{loading}}">
        <text>加载中...</text>
    </view>
</view>