.container {
    padding: 20rpx;
    background-color: #f5f5f5;
    min-height: 100vh;
}

.tab-bar {
    display: flex;
    justify-content: space-around;
    background-color: #fff;
    padding: 20rpx 0;
    margin-bottom: 20rpx;
    border-radius: 10rpx;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.tab-item {
    padding: 10rpx 20rpx;
    font-size: 28rpx;
    color: #666;
    position: relative;
}

.tab-item.active {
    color: #238E23;
    font-weight: bold;
}

.tab-item.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 20rpx;
    right: 20rpx;
    height: 4rpx;
    background-color: #238E23;
    border-radius: 2rpx;
}

.content {
    padding-bottom: 40rpx;
}

/* 优惠活动样式 */
.activity-list {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
}

.activity-item {
    background-color: #fff;
    border-radius: 16rpx;
    overflow: hidden;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.activity-image {
    width: 100%;
    height: 300rpx;
}

.activity-info {
    padding: 30rpx;
}

.activity-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16rpx;
}

.activity-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    flex: 1;
}

.activity-type {
    font-size: 22rpx;
    color: #fff;
    background: linear-gradient(135deg, #238E23 0%, #4CAF50 100%);
    padding: 6rpx 16rpx;
    border-radius: 20rpx;
}

.activity-description {
    font-size: 26rpx;
    color: #666;
    line-height: 1.6;
    margin-bottom: 20rpx;
}

.activity-details {
    background-color: #f8f9fa;
    border-radius: 12rpx;
    padding: 20rpx;
    margin-bottom: 20rpx;
}

.detail-row {
    display: flex;
    align-items: center;
    margin-bottom: 12rpx;
}

.detail-row:last-child {
    margin-bottom: 0;
}

.detail-label {
    font-size: 24rpx;
    color: #999;
    margin-right: 12rpx;
}

.detail-value {
    font-size: 28rpx;
    color: #238E23;
    font-weight: bold;
}

.activity-time {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20rpx;
    padding: 16rpx;
    background-color: #fff3e0;
    border-radius: 8rpx;
}

.time-text {
    font-size: 24rpx;
    color: #666;
}

.remaining-time {
    font-size: 24rpx;
    color: #ff5722;
    font-weight: bold;
}

.activity-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.sold-count {
    font-size: 24rpx;
    color: #999;
}

.join-btn {
    background: linear-gradient(135deg, #238E23 0%, #4CAF50 100%);
    color: #fff;
    border: none;
    border-radius: 30rpx;
    padding: 16rpx 40rpx;
    font-size: 28rpx;
}

/* 优惠券样式 */
.coupon-list {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
}

.coupon-item {
    display: flex;
    background: linear-gradient(135deg, #fff 0%, #f8f9fa 100%);
    border-radius: 16rpx;
    overflow: hidden;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
    border-left: 6rpx solid #238E23;
}

.coupon-left {
    flex: 1;
    display: flex;
    padding: 30rpx;
    align-items: center;
}

.coupon-amount {
    width: 120rpx;
    height: 120rpx;
    background: linear-gradient(135deg, #238E23 0%, #4CAF50 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 24rpx;
}

.amount-text {
    font-size: 36rpx;
    font-weight: bold;
    color: #fff;
}

.coupon-info {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.coupon-name {
    font-size: 30rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 8rpx;
}

.coupon-desc {
    font-size: 24rpx;
    color: #666;
    margin-bottom: 8rpx;
}

.coupon-time {
    font-size: 22rpx;
    color: #999;
}

.coupon-right {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 30rpx 24rpx;
    border-left: 2rpx dashed #e0e0e0;
}

.claim-btn {
    background: linear-gradient(135deg, #238E23 0%, #4CAF50 100%);
    color: #fff;
    border: none;
    border-radius: 30rpx;
    padding: 12rpx 32rpx;
    font-size: 26rpx;
    margin-bottom: 12rpx;
}

.claim-btn[disabled] {
    background: #ccc;
    color: #999;
}

.coupon-limit {
    font-size: 20rpx;
    color: #999;
}

/* 空状态 */
.empty-state {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 100rpx 0;
    color: #999;
    font-size: 28rpx;
}

/* 加载中 */
.loading {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 40rpx 0;
    color: #999;
    font-size: 28rpx;
}
