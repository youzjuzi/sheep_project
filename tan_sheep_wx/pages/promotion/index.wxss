.container {
    padding: 20rpx;
    background-color: #f5f5f5;
    min-height: 100vh;
}

.content {
    padding-bottom: 40rpx;
}

/* 优惠券样式 */
.coupon-list {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
    padding-bottom: 40rpx;
}

.coupon-item {
    display: flex;
    background: linear-gradient(135deg, #fff 0%, #f8f9fa 100%);
    border-radius: 16rpx;
    overflow: hidden;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
    border-left: 6rpx solid #238E23;
    box-sizing: border-box;
    width: 100%;
}

.coupon-left {
    flex: 1;
    display: flex;
    padding: 20rpx;
    align-items: center;
    min-width: 0; /* 防止内容过长撑开 */
}

.coupon-amount {
    width: 100rpx;
    height: 100rpx;
    background: linear-gradient(135deg, #238E23 0%, #4CAF50 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 20rpx;
    flex-shrink: 0;
}

.amount-text {
    font-size: 30rpx;
    font-weight: bold;
    color: #fff;
}

.coupon-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
}

.coupon-name {
    font-size: 28rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 6rpx;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.coupon-owner {
    font-size: 22rpx;
    color: #ff9800;
    margin-bottom: 6rpx;
    background-color: #fff3e0;
    padding: 2rpx 8rpx;
    border-radius: 4rpx;
    align-self: flex-start;
    max-width: 100%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.coupon-desc {
    font-size: 22rpx;
    color: #666;
    margin-bottom: 6rpx;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.coupon-time {
    font-size: 20rpx;
    color: #999;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.coupon-right {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 16rpx 10rpx;
    border-left: 2rpx dashed #e0e0e0;
    width: 150rpx;
    flex-shrink: 0;
    box-sizing: border-box;
}

.claim-btn {
    background: linear-gradient(135deg, #238E23 0%, #4CAF50 100%);
    color: #fff;
    border: none;
    border-radius: 30rpx;
    padding: 0; /* 移除内边距，完全由高度和flex控制 */
    font-size: 24rpx;
    margin-bottom: 8rpx;
    width: 100%;
    height: 50rpx; /* 固定高度 */
    line-height: 50rpx; /* 垂直居中 */
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
}

.claim-btn.disabled {
    background: #ccc;
    color: #fff;
    pointer-events: none;
}

.coupon-limit {
    font-size: 20rpx;
    color: #999;
}

/* 空状态 */
.empty-state {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 100rpx 0;
    color: #999;
    font-size: 28rpx;
}

/* 加载中 */
.loading {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 40rpx 0;
    color: #999;
    font-size: 28rpx;
}
