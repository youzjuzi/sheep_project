.root {
    display: flex;
    flex-direction: column;
    background-color: #f5f5f5;
    min-height: 100vh;
}

.item {
    display: flex;
    align-items: center;
    padding: 15px;
    background-color: #fff;
    margin-bottom: 1px;
}

.breeder-icon {
    width: 60px;   
    height: 60px; 
    margin-right: 12px;
    border-radius: 50%;
    border: 2px solid #238E23;
}

.breeder-info {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.breeder-name-row {
    display: flex;
    align-items: center;
    margin-bottom: 6px;
}

.breeder-name {
    font-size: 18px;
    font-weight: bold;
    color: #333;
    margin-right: 10px;
}

.breeder-rating {
    font-size: 14px;
    color: #ff9800;
}

.breeder-details {
    display: flex;
    flex-direction: column;
    margin-bottom: 6px;
}

.breeder-detail {
    font-size: 13px;
    color: #666;
    margin-bottom: 3px;
}

.breeder-stats {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    margin-top: 5px;
}

.stat-item {
    font-size: 12px;
    color: #666;
    margin-right: 10px;
}

.stat-item.actual {
    color: #238E23;
    font-weight: 500;
}

.stat-item.healthy {
    color: #4CAF50;
    font-weight: 500;
}

.breeder-meta {
    display: flex;
    margin-top: 4px;
}

.meta-item {
    font-size: 11px;
    color: #999;
}

.symbol {
    font-size: 18px;   
    color: #999;
    margin-left: 10px;
}

.divider {
    height: 1px;
    background: #e5e5e5;
    margin: 0;
}

.empty-tip {
    text-align: center;
    padding: 40px 20px;
    color: #999;
    font-size: 14px;
}
  