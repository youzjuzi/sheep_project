.root {
    display: flex;
    flex-direction: column;
    background-color: #f5f5f5;
    min-height: 100vh;
}

.item {
    display: flex;
    align-items: center;
    padding: 15px;
    background-color: #fff;
    margin-bottom: 1px;
}

.breeder-icon {
    width: 60px;
    height: 60px;
    margin-right: 12px;
    border-radius: 50%;
    border: 2px solid #238E23;
}

.breeder-info {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.breeder-name-row {
    display: flex;
    align-items: center;
    margin-bottom: 6px;
}

.breeder-name {
    font-size: 18px;
    font-weight: bold;
    color: #333;
    margin-right: 10px;
}

.breeder-rating {
    font-size: 14px;
    color: #ff9800;
}

.breeder-details {
    display: flex;
    flex-direction: column;
    margin-bottom: 6px;
}

.breeder-detail {
    font-size: 13px;
    color: #666;
    margin-bottom: 3px;
}

.breeder-stats {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    margin-top: 5px;
}

.stat-item {
    font-size: 12px;
    color: #666;
    margin-right: 10px;
}

.stat-item.actual {
    color: #238E23;
    font-weight: 500;
}

.stat-item.healthy {
    color: #4CAF50;
    font-weight: 500;
}

.breeder-meta {
    display: flex;
    margin-top: 4px;
}

.meta-item {
    font-size: 11px;
    color: #999;
}

.symbol {
    font-size: 18px;
    color: #999;
    margin-left: 10px;
}

.divider {
    height: 1px;
    background: #e5e5e5;
    margin: 0;
}

.pagination {
    margin: 18rpx 24rpx 8rpx;
    padding: 14rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #fff;
    border-radius: 12rpx;
}

.page-btn {
    min-width: 120rpx;
    text-align: center;
    font-size: 24rpx;
    color: #238E23;
    padding: 10rpx 14rpx;
    border: 1rpx solid #238E23;
    border-radius: 10rpx;
}

.page-btn.disabled {
    color: #b5b5b5;
    border-color: #e0e0e0;
}

.page-number-wrap {
    display: flex;
    align-items: center;
    gap: 8rpx;
}

.page-number {
    min-width: 56rpx;
    height: 56rpx;
    line-height: 56rpx;
    text-align: center;
    font-size: 24rpx;
    color: #666;
    border-radius: 8rpx;
    background: #f2f4f6;
}

.page-number.active {
    color: #fff;
    background: #238E23;
}

.page-indicator {
    text-align: center;
    font-size: 22rpx;
    color: #888;
    margin-bottom: 18rpx;
}

.empty-tip {
    text-align: center;
    padding: 40px 20px;
    color: #999;
    font-size: 14px;
}
