.container {
    padding: 0;
    background-color: #f5f5f5;
    min-height: 100vh;
}

/* 头部卡片 */
.header-card {
    display: flex;
    align-items: center;
    padding: 20px;
    background: linear-gradient(135deg, #238E23 0%, #4CAF50 100%);
    color: #fff;
    margin-bottom: 10px;
}

.breeder-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 3px solid rgba(255, 255, 255, 0.3);
    margin-right: 15px;
}

.header-info {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.name-row {
    display: flex;
    align-items: center;
    margin-bottom: 8px;
    flex-wrap: wrap;
}

.breeder-name {
    font-size: 22px;
    font-weight: bold;
    margin-right: 10px;
}

.breeder-gender {
    font-size: 14px;
    opacity: 0.9;
    margin-right: 10px;
}

.breeder-rating {
    font-size: 16px;
    color: #ffd700;
}

.breeder-experience {
    font-size: 13px;
    opacity: 0.8;
}

.follow-btn {
    padding: 4px 8px;
    border: 1.5px solid #fff;
    background-color: transparent;
    color: #fff;
    border-radius: 16px;
    font-size: 11px;
}

.follow-btn.followed {
    background-color: #fff;
    color: #238E23;
}

/* 卡片样式 */
.card {
    background-color: #fff;
    margin-bottom: 10px;
    padding: 16px;
    border-radius: 0;
}

.card-title {
    font-size: 18px;
    font-weight: bold;
    color: #333;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 2px solid #238E23;
}

.card-content {
    font-size: 15px;
    color: #666;
    line-height: 1.6;
}

.info-section {
    display: flex;
    align-items: center;
    margin-bottom: 12px;
    padding: 8px 0;
}

.info-section:last-child {
    margin-bottom: 0;
}

.label {
    font-weight: 500;
    font-size: 15px;
    color: #666;
    min-width: 100px;
}

.data {
    flex: 1;
    font-size: 15px;
    color: #333;
}

.data.phone {
    color: #238E23;
    font-weight: 500;
}

.data.address {
    color: #666;
    flex: 1;
}

.map-icon {
    margin-left: 8px;
    font-size: 16px;
}

.loading {
    text-align: center;
    padding: 40px;
    color: #999;
    font-size: 14px;
}

/* 数据统计卡片 */
.stats-cards {
    display: flex;
    padding: 15px;
    background-color: #fff;
    margin-bottom: 10px;
    justify-content: space-around;
}

.stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    padding: 10px;
}

.stat-value {
    font-size: 24px;
    font-weight: bold;
    color: #238E23;
    margin-bottom: 5px;
}

.stat-label {
    font-size: 12px;
    color: #666;
}

/* 羊只列表 */
.sheep-list {
    max-height: 600rpx;
}

.sheep-item {
    display: flex;
    align-items: center;
    padding: 12px;
    margin-bottom: 10px;
    background-color: #f9f9f9;
    border-radius: 8px;
    border-left: 3px solid #238E23;
}

.sheep-item:last-child {
    margin-bottom: 0;
}

.sheep-image {
    width: 80rpx;
    height: 80rpx;
    border-radius: 8px;
    margin-right: 12px;
    background-color: #e0e0e0;
}

.sheep-info {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.sheep-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
}

.sheep-id {
    font-size: 16px;
    font-weight: bold;
    color: #333;
}

.sheep-status {
    display: flex;
    align-items: center;
}

.status-badge {
    padding: 2px 8px;
    border-radius: 10px;
    font-size: 11px;
    font-weight: 500;
}

.status-badge.healthy {
    background-color: #e8f5e9;
    color: #2e7d32;
}

.status-badge.unhealthy {
    background-color: #fff3e0;
    color: #e65100;
}

.sheep-details {
    display: flex;
    flex-wrap: wrap;
    margin-bottom: 4px;
}

.detail-item {
    font-size: 12px;
    color: #666;
    margin-right: 12px;
    margin-bottom: 4px;
}

.sheep-vaccine {
    margin-top: 4px;
}

.vaccine-text {
    font-size: 11px;
    color: #238E23;
}

.arrow {
    font-size: 24px;
    color: #999;
    margin-left: 8px;
}

/* 其他样式 */
.breeder-meta {
    display: flex;
    align-items: center;
    margin-top: 4px;
}

.followers {
    font-size: 12px;
    opacity: 0.8;
}

.card-subtitle {
    font-size: 14px;
    font-weight: normal;
    color: #999;
    margin-left: 8px;
}

.data.success {
    color: #238E23;
}

.data.warning {
    color: #ff9800;
}

.warning-icon {
    margin-left: 5px;
    font-size: 14px;
}

.phone-icon {
    margin-left: 8px;
    font-size: 16px;
    color: #238E23;
}