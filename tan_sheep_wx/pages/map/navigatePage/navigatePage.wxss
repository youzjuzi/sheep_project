/* pages/feature3/navigatePage/navigatePage.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.map {
  width: 100%;
  flex: 1;
  height: 0; /* 配合flex使用 */
}

/* 搜索区域 */
.search-section {
  background-color: #fff;
  padding: 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.search-item {
  margin-bottom: 24rpx;
}

.search-item:last-of-type {
  margin-bottom: 30rpx;
}

.search-label {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  padding-right: 72rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.search-input:focus {
  background-color: #fff;
  border: 2rpx solid #238E23;
}

.select-btn {
  position: absolute;
  right: 8rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #238E23;
  border-radius: 8rpx;
  font-size: 32rpx;
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(35, 142, 35, 0.3);
  z-index: 10;
}

/* 起点和终点按钮更集中 */
.select-btn-start {
  right: 8rpx;
}

.select-btn-end {
  right: 8rpx;
}

.select-btn:active {
  transform: scale(0.95);
  background-color: #1a6b1a;
}

.search-button {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #238E23 0%, #2db82d 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(35, 142, 35, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-button:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(35, 142, 35, 0.2);
}

.search-button[disabled] {
  background: #ccc;
  box-shadow: none;
}

/* 按钮组 */
.button-group {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.button-group .search-button {
  flex: 1;
}

.direct-nav-button {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.direct-nav-button:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.2);
}

.direct-nav-button[disabled] {
  background: #ccc;
  box-shadow: none;
  opacity: 0.6;
}

.direct-nav-button.recommended {
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.4);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.4);
  }
  50% {
    box-shadow: 0 6rpx 20rpx rgba(82, 196, 26, 0.6);
  }
}

.search-button.disabled-hint {
  background: #f5f5f5;
  color: #999;
  border: 2rpx dashed #ccc;
}

/* API状态提示 */
.api-status-hint {
  margin-top: 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #fff7e6 0%, #fffbe6 100%);
  border-left: 6rpx solid #faad14;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(250, 173, 20, 0.1);
}

.hint-content {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.hint-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.hint-text-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.hint-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #d46b08;
  margin-bottom: 8rpx;
}

.hint-text {
  font-size: 24rpx;
  color: #d46b08;
  line-height: 1.6;
}

.hint-steps {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(212, 107, 8, 0.2);
}

.step-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #d46b08;
  display: block;
  margin-bottom: 12rpx;
}

.step-item {
  font-size: 24rpx;
  color: #d46b08;
  display: block;
  margin-bottom: 8rpx;
  padding-left: 20rpx;
  line-height: 1.6;
}

/* 快速操作 */
.quick-action {
  margin-top: 12rpx;
  display: flex;
  justify-content: flex-end;
}

.quick-btn {
  font-size: 24rpx;
  color: #238E23;
  padding: 8rpx 16rpx;
  background-color: #f0f9f0;
  border-radius: 20rpx;
  border: 1rpx solid #238E23;
}

.quick-btn:active {
  background-color: #e0f0e0;
}

/* 位置操作 */
.location-actions {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}

.back-to-location-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #238E23 0%, #2db82d 100%);
  color: #fff;
  border-radius: 50rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(35, 142, 35, 0.3);
  min-width: 200rpx;
}

.back-to-location-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(35, 142, 35, 0.2);
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.btn-text {
  font-size: 28rpx;
}

/* 路线信息卡片 */
.route-info-card {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
  max-height: 50vh;
  overflow-y: auto;
}

.route-info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.route-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.route-clear {
  font-size: 26rpx;
  color: #999;
  padding: 8rpx 16rpx;
}

.route-clear:active {
  color: #238E23;
}

.route-info-content {
  margin-bottom: 24rpx;
}

.route-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.route-item:last-child {
  margin-bottom: 0;
}

.route-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.route-text {
  font-size: 28rpx;
  color: #333;
}

.nav-button {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #238E23 0%, #2db82d 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(35, 142, 35, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-button:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(35, 142, 35, 0.2);
}
