<view class="container">
    <map
      id="map"
      longitude="{{longitude}}"
      latitude="{{latitude}}"
      scale="{{scale}}"
      markers="{{markers}}"
      polygons="{{polygons}}"
      show-location
      bindmarkertap="onMarkerTap"
      bindregionchange="onRegionChange"
      style="width: 100%; height: 100vh;"
    ></map>

    <!-- 加载提示 -->
    <view class="loading-overlay" wx:if="{{loading}}">
        <view class="loading-content">
            <text>加载中...</text>
        </view>
    </view>

    <view class="modal" wx:if="{{selectedFarmer}}">
        <view class="modal-header">农户信息</view>
        <view class="modal-content">
            <view class="modal-item">
                <text class="modal-label">名称：</text>{{selectedFarmer.name}}
            </view>
            <view class="modal-item">
                <text class="modal-label">性别：</text>{{selectedFarmer.gender}}
            </view>
            <view class="modal-item">
                <text class="modal-label">手机号：</text>{{selectedFarmer.phone}}
            </view>
            <view class="modal-item">
                <text class="modal-label">养殖羊的数量：</text>{{selectedFarmer.actual_sheep_count || selectedFarmer.sheep_count}}只
            </view>
            <view class="modal-item" wx:if="{{selectedFarmer.address}}">
                <text class="modal-label">地址：</text>{{selectedFarmer.address}}
            </view>
            <view class="modal-buttons">
                <button class="nav-button" bindtap="navigateToLocation">🗺️ 打开地图</button>
                <button class="close-button" bindtap="closeModal">关闭</button>
            </view>
        </view>
    </view>

    <!-- 地图应用入口按钮（浮动） -->
    <view class="nav-fab" bindtap="openNavigation">
        <text class="nav-fab-icon">🧭</text>
        <text class="nav-fab-text">地图</text>
    </view>
</view>
