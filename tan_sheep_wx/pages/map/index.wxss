.container {
    width: 100%;
    height: 100vh;
    position: relative;
  }
  .modal {
    position: absolute;
    bottom: 0;
    width: 100%;
    background-color: #fff;
    padding: 20px 16px;
    box-shadow: 0 -4px 10px rgba(0, 0, 0, 0.3);
    border-radius: 10px 10px 0 0;
  }

  .modal-header {
    text-align: center;
    font-size: 18px;
    font-weight: bold;
    color: #333;
    margin-bottom: 16px;
  }

  .modal-content {
    line-height: 1.8;
    font-size: 16px;
    color: #555;
  }

  .modal-item {
    margin-bottom: 10px;
  }

  .modal-label {
    font-weight: bold;
    color: #333;
  }

  .modal-buttons {
    display: flex;
    gap: 20rpx;
    margin-top: 30rpx;
  }

  .nav-button {
    flex: 1;
    padding: 20rpx;
    background: linear-gradient(135deg, #238E23 0%, #2db82d 100%);
    color: white;
    border-radius: 12rpx;
    font-size: 28rpx;
    text-align: center;
    border: none;
    box-shadow: 0 4rpx 12rpx rgba(35, 142, 35, 0.3);
  }

  .nav-button:active {
    transform: scale(0.98);
  }

  .close-button {
    flex: 1;
    padding: 20rpx;
    background-color: #f5f5f5;
    color: #333;
    border-radius: 12rpx;
    font-size: 28rpx;
    text-align: center;
    border: none;
  }

  .close-button:active {
    background-color: #e0e0e0;
  }

  /* 导航浮动按钮 */
  .nav-fab {
    position: fixed;
    right: 30rpx;
    bottom: 120rpx;
    width: 120rpx;
    height: 120rpx;
    background: linear-gradient(135deg, #238E23 0%, #2db82d 100%);
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8rpx 20rpx rgba(35, 142, 35, 0.4);
    z-index: 100;
  }

  .nav-fab-icon {
    font-size: 48rpx;
    margin-bottom: 4rpx;
  }

  .nav-fab-text {
    font-size: 20rpx;
    color: #fff;
  }

  .nav-fab:active {
    transform: scale(0.9);
  }

  /* 加载提示 */
  .loading-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
  }

  .loading-content {
    background-color: #fff;
    padding: 30rpx 50rpx;
    border-radius: 10rpx;
    font-size: 28rpx;
    color: #333;
  }
  