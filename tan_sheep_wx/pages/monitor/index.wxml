<!--pages/feature6/feature6.wxml-->
<view class="monitor-page">
  <!-- 顶部统计卡片 -->
  <view class="stats-container">
    <view class="stats-card">
      <view class="stats-item">
        <text class="stats-value">{{statistics.totalMonitors}}</text>
        <text class="stats-label">监控总数</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-value" style="color: #52c41a;">{{statistics.onlineMonitors}}</text>
        <text class="stats-label">在线监控</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-value">{{statistics.totalSheep}}</text>
        <text class="stats-label">羊只总数</text>
      </view>
    </view>
  </view>

  <!-- 监控列表 -->
  <view class="monitor-list">
    <view 
      class="monitor-card" 
      wx:for="{{monitors}}" 
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goToMonitor">
      
      <!-- 监控图标和基本信息 -->
      <view class="monitor-header">
        <view class="monitor-icon-wrapper">
          <image class="monitor-icon" src="{{item.icon}}" mode="aspectFill"></image>
          <view class="status-dot" style="background-color: {{item.status === 'online' ? '#52c41a' : '#999'}}"></view>
        </view>
        <view class="monitor-info">
          <view class="monitor-name">{{item.name}}</view>
          <view class="monitor-location">{{item.location}}</view>
        </view>
        <view class="monitor-status">
          <text class="status-text" style="color: {{item.status === 'online' ? '#52c41a' : '#999'}}">
            {{item.status === 'online' ? '● 在线' : '○ 离线'}}
          </text>
        </view>
      </view>

      <!-- 监控详情 -->
      <view class="monitor-details">
        <view class="detail-item">
          <text class="detail-label">🐏 羊只数量：</text>
          <text class="detail-value">{{item.sheepCount}} 只</text>
        </view>
        <view class="detail-item">
          <text class="detail-label">🕐 更新时间：</text>
          <text class="detail-value">{{item.lastUpdate}}</text>
        </view>
      </view>

      <!-- 箭头图标 -->
      <view class="monitor-arrow">
        <text class="arrow-icon">›</text>
      </view>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tips">
    <text class="tips-text">💡 提示：点击监控卡片查看实时视频和详细信息</text>
  </view>

  <!-- 刷新按钮（浮动） -->
  <view class="refresh-fab" bindtap="refreshData">
    <text class="refresh-icon">🔄</text>
  </view>
</view>
