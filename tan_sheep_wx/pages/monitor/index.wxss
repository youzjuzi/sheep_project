/* pages/feature6/feature6.wxss */
.monitor-page {
  min-height: 100vh;
  background: linear-gradient(to bottom, #f0f9ff 0%, #f5f5f5 100%);
  padding-bottom: 120rpx;
}

/* 统计卡片 */
.stats-container {
  padding: 30rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: linear-gradient(135deg, #238E23 0%, #2db82d 100%);
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(35, 142, 35, 0.2);
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stats-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.stats-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

/* 监控列表 */
.monitor-list {
  padding: 0 30rpx;
}

.monitor-card {
  background-color: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  position: relative;
  transition: all 0.3s ease;
  overflow: hidden;
}

.monitor-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: linear-gradient(to bottom, #238E23, #2db82d);
}

.monitor-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

/* 监控头部 */
.monitor-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.monitor-icon-wrapper {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  margin-right: 24rpx;
}

.monitor-icon {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  background-color: #f0f0f0;
}

.status-dot {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.monitor-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.monitor-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.monitor-location {
  font-size: 24rpx;
  color: #666;
}

.monitor-status {
  display: flex;
  align-items: center;
}

.status-text {
  font-size: 24rpx;
  font-weight: 500;
}

/* 监控详情 */
.monitor-details {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  margin-bottom: 10rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-label {
  font-size: 26rpx;
  color: #666;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* 箭头 */
.monitor-arrow {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
}

.arrow-icon {
  font-size: 48rpx;
  color: #ccc;
  font-weight: 300;
}

/* 底部提示 */
.footer-tips {
  padding: 30rpx;
  text-align: center;
}

.tips-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

/* 刷新按钮（浮动） */
.refresh-fab {
  position: fixed;
  right: 30rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #238E23 0%, #2db82d 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(35, 142, 35, 0.4);
  z-index: 100;
}

.refresh-icon {
  font-size: 48rpx;
  color: #fff;
  animation: rotate 2s linear infinite;
}

.refresh-fab:active {
  transform: scale(0.9);
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* 响应式调整 */
@media (max-width: 375px) {
  .stats-value {
    font-size: 40rpx;
  }
  
  .monitor-icon-wrapper {
    width: 80rpx;
    height: 80rpx;
  }
}
