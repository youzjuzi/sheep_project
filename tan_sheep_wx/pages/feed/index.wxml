<view class="feed-page">

  <!-- 页头 -->
  <view class="feed-header">
    <text class="feed-header-icon">🌾</text>
    <text class="feed-header-title">日常饲料指南</text>
    <text class="feed-header-sub">宁夏盐池滩羊科学喂养</text>
  </view>

  <!-- 饲料分类 -->
  <view class="section">
    <view class="section-title">🗂️ 饲料分类</view>
    <view class="feed-grid">

      <view class="feed-card color-green">
        <text class="feed-card-icon">🌿</text>
        <text class="feed-card-name">粗饲料</text>
        <text class="feed-card-desc">牧草、野草、青干草、树叶、大豆秸秆、花生秧、稻草、玉米秸秆</text>
      </view>

      <view class="feed-card color-yellow">
        <text class="feed-card-icon">🌽</text>
        <text class="feed-card-name">精饲料</text>
        <text class="feed-card-desc">玉米、大麦、麦麸、豆粕、花生粕</text>
      </view>

      <view class="feed-card color-brown">
        <text class="feed-card-icon">🍺</text>
        <text class="feed-card-name">糟粕饲料</text>
        <text class="feed-card-desc">白酒糟、啤酒糟、醋糟、豆腐渣</text>
      </view>

      <view class="feed-card color-blue">
        <text class="feed-card-icon">💊</text>
        <text class="feed-card-name">添加剂</text>
        <text class="feed-card-desc">预混料、瘤胃素、小苏打、健胃散</text>
      </view>

    </view>
  </view>

  <!-- 生长阶段饲料 -->
  <view class="section">
    <view class="section-title">📅 生长阶段与饲料</view>

    <!-- 幼羊期 -->
    <view class="stage-card">
      <view class="stage-header stage-baby">
        <text class="stage-icon">🐑</text>
        <view class="stage-info">
          <text class="stage-name">幼羊期</text>
          <text class="stage-age">出生 ~ 6个月</text>
        </view>
      </view>
      <view class="stage-body">
        <view class="feed-tag-row">
          <view class="feed-tag">🥛 母乳</view>
          <view class="feed-tag">🌱 青干草（适量）</view>
          <view class="feed-tag">🌿 牧草（适量）</view>
        </view>
        <text class="stage-tip">💡 以母乳为主，逐步引入少量植物性饲料</text>
      </view>
    </view>

    <!-- 青年期 -->
    <view class="stage-card">
      <view class="stage-header stage-young">
        <text class="stage-icon">🐏</text>
        <view class="stage-info">
          <text class="stage-name">青年期</text>
          <text class="stage-age">6个月 ~ 1岁</text>
        </view>
      </view>
      <view class="stage-body">
        <view class="feed-tag-row">
          <view class="feed-tag">🌿 牧草·野草</view>
          <view class="feed-tag">🌱 青干草</view>
          <view class="feed-tag">🍃 树叶·秸秆</view>
          <view class="feed-tag">🌽 少量玉米</view>
          <view class="feed-tag">🫘 少量豆粕</view>
        </view>
        <text class="stage-tip">💡 断奶后逐步增加粗饲料与精饲料比例，支持快速生长</text>
      </view>
    </view>

    <!-- 成年期 -->
    <view class="stage-card">
      <view class="stage-header stage-adult">
        <text class="stage-icon">🐑</text>
        <view class="stage-info">
          <text class="stage-name">成年期</text>
          <text class="stage-age">1岁以上</text>
        </view>
      </view>
      <view class="stage-body">
        <view class="feed-tag-row">
          <view class="feed-tag">🌿 牧草·干草</view>
          <view class="feed-tag">🌽 玉米·大麦</view>
          <view class="feed-tag">🫘 豆粕·花生粕</view>
          <view class="feed-tag">🍺 酒糟·醋糟</view>
          <view class="feed-tag">💊 添加剂</view>
        </view>
        <text class="stage-tip">💡 饲料多样化，均衡营养以维持健康与生产性能</text>
      </view>
    </view>

  </view>

  <view style="height: 40rpx;"></view>
</view>
