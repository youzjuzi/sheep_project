/* 日常饲料页面样式 */
page { background: #f4f6f3; }

.feed-page {
  padding: 0 0 40rpx;
}

/* 页头 */
.feed-header {
  background: linear-gradient(135deg, #4caf50, #81c784);
  padding: 60rpx 40rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.feed-header-icon { font-size: 72rpx; margin-bottom: 12rpx; }
.feed-header-title { font-size: 40rpx; font-weight: 700; color: #fff; }
.feed-header-sub { font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; }

/* 通用 section */
.section {
  margin: 30rpx 30rpx 0;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 4rpx;
}

/* 饲料分类列表 */
.feed-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.feed-card {
  width: 100%;
  box-sizing: border-box;
  border-radius: 20rpx;
  padding: 28rpx 22rpx;
  display: flex;
  flex-direction: column;
}
.feed-card-icon { font-size: 52rpx; margin-bottom: 10rpx; }
.feed-card-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}
.feed-card-desc {
  font-size: 22rpx;
  color: #555;
  line-height: 1.5;
}
.color-green  { background: #e8f5e9; }
.color-yellow { background: #fffde7; }
.color-brown  { background: #fbe9e7; }
.color-blue   { background: #e3f2fd; }

/* 生长阶段卡片 */
.stage-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.stage-header {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  gap: 20rpx;
}
.stage-baby  { background: #fce4ec; }
.stage-young { background: #e8f5e9; }
.stage-adult { background: #e3f2fd; }

.stage-icon { font-size: 56rpx; }
.stage-info { display: flex; flex-direction: column; }
.stage-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}
.stage-age {
  font-size: 22rpx;
  color: #888;
  margin-top: 4rpx;
}
.stage-body {
  padding: 22rpx 28rpx 28rpx;
}

/* 饲料标签 */
.feed-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 20rpx;
}
.feed-tag {
  background: #f5f5f5;
  border-radius: 30rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #444;
}

/* 提示文字 */
.stage-tip {
  font-size: 22rpx;
  color: #888;
  background: #fafafa;
  border-radius: 10rpx;
  padding: 14rpx 18rpx;
  line-height: 1.6;
}
