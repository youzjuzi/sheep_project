/* 羊的饲料页面的 wxss 文件 */
.container {
    padding: 20px;
}

.feed-item {
    background-color: #f9f9f9;
    padding: 10px;
    margin-bottom: 10px;
    border-radius: 8px;
}

.feed-type {
    font-size: 16px;
    font-weight: bold;
    color: #333;
}

.feed-list {
    font-size: 14px;
    color: #666;
    margin-top: 5px;
}
.title{
    background-color: #f9f9f9;
    padding: 10px;
    margin-bottom: 10px;
    border-radius: 8px;
    font-size: 20px;
    color: darkseagreen;
}
image{
    width: 90px;
    height: 90px;
    border-radius: 20px;
}.divider {
    height: 10px;
    background: linear-gradient(to right, red, orange, yellow, green, blue, indigo, violet);
    margin: 5px 0;
}
