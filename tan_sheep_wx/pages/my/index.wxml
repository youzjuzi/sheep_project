<!--pages/my/index.wxml - 重新设计版-->
<view class="my-page">
  <!-- 顶部个人信息区 -->
  <view class="header-section">
    <!-- 未登录状态 -->
    <view wx:if="{{ !apiUserInfoMap }}" class="header-not-login">
      <image class="default-avatar" src="/pages/my/images/user.png" mode="aspectFill"></image>
      <view class="login-prompt">
        <text class="login-text">登录后享受更多服务</text>
        <van-button type="primary" size="small" round bind:click="login" custom-class="login-btn">
          立即登录
        </van-button>
      </view>
    </view>
    
    <!-- 已登录状态 -->
    <view wx:else class="header-logged-in">
      <button class="avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <image class="avatar-img" src="{{ apiUserInfoMap.base.avatarUrl || '/pages/my/images/user.png' }}" mode="aspectFill"></image>
        <view class="avatar-badge">
          <van-icon name="photo-o" size="28rpx" color="#fff"></van-icon>
        </view>
      </button>
      <view class="user-details">
        <view class="nickname-row">
          <text class="nickname">{{ apiUserInfoMap.base.nick || '未设置昵称' }}</text>
          <van-icon name="edit" size="28rpx" color="#999" class="edit-icon" bindtap="editNick"></van-icon>
        </view>
        <view class="user-meta">
          <text class="user-id" bind:tap="copyUid">ID: {{ apiUserInfoMap.base.id }}</text>
          <view wx:if="{{ apiUserInfoMap.base.mobile }}" class="mobile-badge">
            <van-icon name="phone-o" size="24rpx" color="#238E23"></van-icon>
            <text class="mobile-text">{{ apiUserInfoMap.base.mobile }}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 我的资产聚合卡 -->
  <view class="asset-card" wx:if="{{ apiUserInfoMap }}" bindtap="goAsset">
    <view class="asset-header">
      <text class="asset-title">我的资产</text>
      <van-icon name="arrow" size="28rpx" color="#999"></van-icon>
    </view>
    <view class="asset-content">
      <view class="asset-item">
        <text class="asset-value">¥{{balance}}</text>
        <text class="asset-label">余额</text>
      </view>
      <view class="asset-divider"></view>
      <view class="asset-item">
        <text class="asset-value">{{score}}</text>
        <text class="asset-label">积分</text>
      </view>
      <view class="asset-divider"></view>
      <view class="asset-item">
        <text class="asset-value">{{couponCount}}</text>
        <text class="asset-label">优惠券</text>
      </view>
    </view>
  </view>

  <!-- 核心功能入口（2x4网格） -->
  <view class="core-functions">
    <view class="function-grid">
      <view 
        class="function-item" 
        wx:for="{{coreFunctions}}" 
        wx:key="index"
        bindtap="handleFunctionTap"
        data-url="{{item.url}}"
        data-type="{{item.type}}">
        <view class="function-icon" style="background-color: {{item.bgColor}}">
          <van-icon name="{{item.icon}}" size="48rpx" color="{{item.iconColor}}"></van-icon>
        </view>
        <text class="function-text">{{item.text}}</text>
        <view wx:if="{{item.badge}}" class="function-badge">{{item.badge}}</view>
      </view>
    </view>
  </view>

  <!-- 服务与工具区 -->
  <view class="tools-section">
    <view class="tools-title">服务与工具</view>
    <view class="tools-list">
      <view 
        class="tool-item" 
        wx:for="{{toolsMenus}}" 
        wx:key="index"
        bindtap="handleToolTap"
        data-url="{{item.url}}"
        data-type="{{item.type}}">
        <view class="tool-icon-wrapper">
          <van-icon name="{{item.icon}}" size="40rpx" color="{{item.color}}"></van-icon>
        </view>
        <text class="tool-text">{{item.text}}</text>
        <van-icon name="arrow" size="28rpx" color="#ccc" class="tool-arrow"></van-icon>
      </view>
    </view>
  </view>

  <!-- 退出登录按钮（仅已登录时显示） -->
  <view wx:if="{{ apiUserInfoMap }}" class="logout-section">
    <van-button type="default" block round custom-class="logout-btn" bind:click="onLogout">
      退出登录
    </van-button>
  </view>
</view>

<!-- 编辑昵称弹窗 -->
<van-dialog
  use-slot
  show="{{ nickShow }}"
  title="修改昵称"
  show-cancel-button
  confirm-button-text="保存"
  cancel-button-text="取消"
  bind:confirm="saveNick"
  bind:cancel="cancelEditNick"
  custom-style="border-radius: 24rpx;"
>
  <view class="nick-input-wrapper">
    <input 
      class="nick-input" 
      type="nickname" 
      placeholder="请输入或获取微信昵称" 
      value="{{ newNick }}" 
      bindinput="onNickInput" 
      bindblur="onNickBlur"
      maxlength="20" 
      confirm-type="done"
      always-embed="true"
    />
  </view>
</van-dialog>
