<view class="container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <van-icon name="flower-o" size="30px" color="#ccc" class="spin-icon"/>
    <text>拼命加载中...</text>
  </view>

  <block wx:if="{{!loading && sheepDetail}}">
    <!-- 头部信息卡片 -->
    <view class="header-card">
      <view class="card-bg"></view>
      <view class="sheep-profile">
        <image class="sheep-avatar" src="{{sheepDetail.image || '/images/icons/function/f1.png'}}" mode="aspectFill" bindtap="previewSheepImage"></image>
        <view class="profile-info">
          <text class="sheep-title">我的滩羊 #{{sheepDetail.id}}</text>
          <view class="id-tag"><van-icon name="label-o"/> {{sheepDetail.ear_tag}}</view>
        </view>
        <view class="status-badge">{{sheepDetail.status}}</view>
      </view>
    </view>

    <!-- 基础数据面板 -->
    <view class="data-panel">
      <view class="data-item">
        <text class="data-val">{{sheepDetail.weight}}<text class="data-unit">kg</text></text>
        <text class="data-label">体重</text>
      </view>
      <view class="data-item">
        <text class="data-val">{{sheepDetail.height}}<text class="data-unit">cm</text></text>
        <text class="data-label">体高</text>
      </view>
      <view class="data-item">
        <text class="data-val">{{sheepDetail.length}}<text class="data-unit">cm</text></text>
        <text class="data-label">体长</text>
      </view>
    </view>

    <!-- 详细档案页签 -->
    <view class="section">
      <view class="section-title"><van-icon name="notes-o" color="#4CAF50"/> 电子档案</view>
      <van-cell-group inset custom-class="custom-cell-group">
        <van-cell title="性别" value="{{sheepDetail.gender}}" />
        <van-cell title="出生日期" value="{{sheepDetail.birth_date}}" />
        <van-cell title="养殖牧场" value="{{sheepDetail.farm_name}}" icon="shop-o" />
        <van-cell title="负责农户" value="{{sheepDetail.breeder_name}}" icon="contact" is-link />
      </van-cell-group>
    </view>

    <!-- 溯源二维码（只有在存在时显示） -->
    <view class="section" wx:if="{{sheepDetail.qr_code}}">
      <view class="section-title"><van-icon name="scan" color="#1989fa"/> 身份标识</view>
      <view class="qr-code-box">
        <image class="qr-code-img" src="{{sheepDetail.qr_code}}" mode="aspectFit" bindtap="previewQRCode"></image>
        <text class="qr-code-hint">点击可放大，扫码验证羊只身份信息</text>
      </view>
    </view>

    <!-- 疫苗与健康 -->
    <view class="section">
      <view class="section-title"><van-icon name="shield-o" color="#1989fa"/> 检疫与健康</view>
      <view class="vaccine-list" wx:if="{{vaccineRecords.length > 0}}">
        <view class="timeline-item" wx:for="{{vaccineRecords}}" wx:key="VaccinationID">
          <view class="timeline-dot"></view>
          <view class="timeline-content">
            <view class="timeline-header">
              <text class="v-type">{{item.VaccineType}}</text>
              <text class="v-date">{{item.VaccinationDate}}</text>
            </view>
            <text class="v-desc">操作人: {{item.AdministeredBy}} | 剂量: {{item.Dosage}}ml</text>
          </view>
        </view>
      </view>
      <view class="empty-list" wx:else>
        <text>该羊只暂无接种记录</text>
      </view>
    </view>

    <!-- 底部操作区 -->
    <view class="action-bar">
      <button class="action-btn primary-btn" bindtap="viewMonitor">查看监控</button>
    </view>
  </block>
</view>
