/* pages/my/index.wxss */
.my-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #238E23 0%, #f5f5f5 30%);
  padding-bottom: 140rpx; /* 防止 tabBar 遮挡 */
}

/* 头部区域 */
.header-section {
  padding: 40rpx 32rpx 60rpx;
}

/* 未登录状态 */
.header-not-login {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.default-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-bottom: 32rpx;
}

.login-text {
  color: #fff;
  font-size: 32rpx;
  margin-bottom: 32rpx;
}

.login-btn-small {
  min-width: 200rpx;
}

/* 已登录状态 */
.header-logged-in {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar-btn {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  border-radius: 50%;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: #238E23;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
}

.user-details {
  margin-left: 32rpx;
  flex: 1;
}

.nickname-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-right: 16rpx;
}

.edit-icon {
  opacity: 0.8;
}

.user-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.user-level {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
}

.user-code-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  min-width: 120rpx;
}

.code-text {
  font-size: 24rpx;
  color: #fff;
  margin-top: 8rpx;
}

/* 数据卡片区域 */
.data-cards {
  display: flex;
  margin: 0 32rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.card-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.card-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

.card-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.balance-icon {
  background: rgba(35, 142, 35, 0.1);
}

.consume-icon {
  background: rgba(255, 152, 0, 0.1);
}

.score-icon {
  background: rgba(255, 215, 0, 0.1);
}

.growth-icon {
  background: rgba(76, 175, 80, 0.1);
}

.card-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card-amount {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.card-label {
  font-size: 24rpx;
  color: #999;
}

/* 功能菜单区域 */
.menu-section {
  margin: 0 32rpx;
}

.menu-group {
  margin-bottom: 32rpx;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

.menu-list {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  position: relative;
}

.menu-item:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 0;
  height: 1rpx;
  background: #f5f5f5;
}

.menu-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
}

.menu-text {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.menu-badge {
  margin-right: 16rpx;
  padding: 4rpx 16rpx;
  background: #ff4444;
  color: #fff;
  font-size: 20rpx;
  border-radius: 20rpx;
}

.menu-arrow {
  opacity: 0.5;
}

/* 编辑昵称弹窗 */
.nick-input-wrapper {
  padding: 32rpx;
}

.nick-input {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  font-size: 32rpx;
  background: #f9f9f9;
}

.nick-input:focus {
  border-color: #238E23;
  background: #fff;
}

/* 资产卡片 */
.asset-card {
  margin: -40rpx 32rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.asset-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.asset-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.asset-content {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.asset-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.asset-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.asset-label {
  font-size: 24rpx;
  color: #999;
}

.asset-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

/* 核心功能入口 */
.core-functions {
  margin: 0 32rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.function-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32rpx 16rpx;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.function-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.function-text {
  font-size: 24rpx;
  color: #333;
  text-align: center;
  line-height: 1.3;
}

.function-badge {
  position: absolute;
  top: 0;
  right: 20rpx;
  background: #ff4444;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 40rpx;
  text-align: center;
}

/* 服务与工具区 */
.tools-section {
  margin: 0 32rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.tools-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  padding: 32rpx 32rpx 16rpx;
}

.tools-list {
  padding: 0 32rpx 32rpx;
}

.tool-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  position: relative;
}

.tool-item:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: #f5f5f5;
}

.tool-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.tool-text {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.tool-arrow {
  opacity: 0.5;
}

/* 退出登录 */
.logout-section {
  margin: 40rpx 32rpx 60rpx;
}

.logout-btn {
  color: #e74c3c !important;
  border-color: #e74c3c !important;
  font-size: 32rpx !important;
}
